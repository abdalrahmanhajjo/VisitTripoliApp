{
  "name": "tripoli-explorer-api",
  "version": "1.0.0",
  "description": "Node.js + MongoDB backend for the Visit Tripoli Flutter app",
  "engines": {
    "node": ">=18"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:always": "pm2 start ecosystem.config.cjs",
    "stop:always": "pm2 stop tripoli-api",
    "restart:always": "pm2 restart tripoli-api",
    "status:always": "pm2 status tripoli-api",
    "dev": "node --watch src/index.js",
    "db:migrate:legacy": "node scripts/mongo-migrate-legacy.js",
    "db:indexes": "node scripts/mongo-create-indexes.js",
    "db:check": "node scripts/mongo-data-check.js",
    "db:setup": "npm run db:migrate:legacy && npm run db:indexes",
    "db:check-feed": "node scripts/check-feed-db.js",
    "db:dump-schema": "node scripts/dump-schema.js",
    "db:apply-supabase-schema": "node scripts/apply-supabase-schema.js",
    "setup": "node scripts/setup.js"
  },
  "dependencies": {
    "@imagekit/nodejs": "^7.4.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "twilio": "^5.12.1",
    "verify-apple-id-token": "^3.1.2"
  }
}
