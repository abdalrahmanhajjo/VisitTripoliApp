# =============================================================================
# Visit Tripoli API — environment template (copy to .env and edit)
#   Copy:  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# Never commit .env (secrets). See DEPLOY_SUPABASE.md, RENDER-500-PLACES.md
# =============================================================================

# --- Core server ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- MongoDB (required for data) ---
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/?appName=VisitTripoli
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=VisitTripoli
MONGODB_DB_NAME=visittripoli
DB_POOL_SIZE=20
# Kept for compatibility with legacy DB clients.
DB_ACCEPT_SELF_SIGNED=1

# --- HTTP security / CORS ---
# Comma-separated origins, or * for allow-all (ok for local dev + Flutter web).
CORS_ORIGIN=*

# Optional: self-hosted OSRM base for GET /api/directions/route (default: public Project OSRM).
# OSRM_BASE_URL=https://router.project-osrm.org/route/v1

# --- Google Maps (in-app directions same as Google Maps) ---
# Server key (never expose in the Flutter app). Enable "Directions API" in Google Cloud Console.
# Driving uses live traffic (best_guess). If unset, the app falls back to OSRM.
# GOOGLE_MAPS_API_KEY=

# Dev only: disable strict TLS verification for outbound HTTPS (avoid in production)
ALLOW_INSECURE_TLS=

# Dev only: POST /api/auth/forgot-password includes devResetCode in JSON (never enable in production)
ENABLE_DEV_CODE=true

# --- Auth & admin ---
# Production: openssl rand -base64 32 (must be >= 32 characters in production)
JWT_SECRET=minimum-32-character-secret-change-this
ADMIN_SECRET=admin-dashboard-secret-change-this

# --- OAuth ---
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Apple: comma-separated audiences — iOS App ID (bundle id) + Android Services ID (same JWT verify).
# Example: com.example.tripoli_explorer,com.example.tripoli_explorer.signin
APPLE_CLIENT_IDS=
# Legacy single value (iOS bundle id OR Services id only):
APPLE_CLIENT_ID=
APPLE_SERVICE_ID=
# Used in intent:// redirect for Sign in with Apple on Android (match Flutter applicationId).
ANDROID_PACKAGE_NAME=com.example.tripoli_explorer

# --- Public URLs (emails, trip share links, deep links) ---
RESET_PASSWORD_BASE_URL=http://localhost:8080
APP_URL=http://localhost:3000

# --- Place / static uploads ---
# Relative path from repo root (see index.js resolution), or absolute
UPLOADS_PATH=
UPLOADS_BASE_URL=
UPLOADS_PORT=3001
WEBTRIPOLI_PORT=3001

# --- ImageKit media storage ---
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_FOLDER=/tripoli-explorer

# --- Email (optional in dev; without it, reset links log to console) ---
APP_NAME=Visit Tripoli
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- SMS (Twilio; optional in dev) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- AI / automation (optional) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
N8N_WEBHOOK_URL=
